# Logtail server credentials — copy to .env and fill in real values.
# The .env file must NOT be committed to source control.

LOG_API_KEY=
LOG_USERNAME=
LOG_PASSWORD=

# Optional: path to a CA bundle PEM file for HTTPS requests to internal servers.
# Leave blank to use the system default CA store.
# For the local logtail dev server use the self-signed cert:
# CA_BUNDLE=/path/to/copilot-local-rag/dummy-data-for-test/certs/logtail.crt
CA_BUNDLE=
