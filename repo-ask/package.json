{
  "name": "repo-ask",
  "displayName": "@RepoAsk",
  "description": "A VS Code plugin for searching and managing Confluence documentation",
  "version": "0.1.0",
  "publisher": "repo-ask",
  "icon": "media/logo.png",
  "engines": {
    "vscode": ">=1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onChatParticipant:repoask",
    "onLanguageModelTool:repoask_doc_check"
  ],
  "main": "out/index.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "repoask",
        "name": "repoask",
        "description": "RepoAsk chat for general questions from the document store",
        "commands": [
          {
            "name": "production-support",
            "description": "Run production support planning using the production-support-plan skill as the starting point"
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "repoask_doc_check",
        "tags": [
          "repoask",
          "relevance",
          "qa"
        ],
        "toolReferenceName": "repoaskCheck",
        "displayName": "RepoAsk Doc Check",
        "modelDescription": "Find relevant local documents for a question using metadata relevance and include local content references.",
        "userDescription": "Check local docs for relevant references.",
        "canBeReferencedInPrompt": true,
        "icon": "$(search)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "User question to evaluate against local metadata and content. Required for search mode."
            },
            "mode": {
              "type": "string",
              "enum": [
                "id_2_title",
                "id_2_content",
                "id_2_metadata",
                "id_2_content_partial",
                "id_2_metadata_4_summary",
                "id_2_metadata_4_summary_kg"
              ],
              "description": "Operation mode. 'id_2_title' returns titles for provided doc ids. 'id_2_content' returns content for provided doc ids. 'id_2_metadata' returns metadata for provided doc ids. 'id_2_content_partial' returns content snippets for provided doc ids. 'id_2_metadata_4_summary' returns metadata optimized for summarization. 'id_2_metadata_4_summary_kg' returns metadata optimized for summarization with knowledge graph traversal."
            },
            "ids": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Optional list of document ids to read. Leave empty to read all."
            },
            "searchTerms": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Will trigger search and ranking to find relevant documents based on these terms. return doc ids."
            },
            "limit": {
              "type": "number",
              "description": "Optional max number of references to return for search mode.",
              "default": 3
            }
          }
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "repo-ask-explorer",
          "title": "RepoAsk",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "repo-ask-explorer": [
        {
          "id": "repo-ask-documents",
          "name": "Documents",
          "type": "webview",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "repo-ask.refresh",
        "title": "RepoAsk: Refresh"
      },
      {
        "command": "repo-ask.showLogActionButton",
        "title": "RepoAsk: Show Log Action Button"
      },
      {
        "command": "repo-ask.checkCodeLogic",
        "title": "RepoAsk: Check Code Logic"
      },
      {
        "command": "repo-ask.advancedDocSearch",
        "title": "RepoAsk: Advanced Doc Search"
      }
    ],
    "configuration": {
      "title": "RepoAsk",
      "properties": {
        "repoAsk.initKeywordNum": {
          "type": "number",
          "default": 50,
          "description": "Init Keyword Num"
        },
        "repoAsk.maxAdvancedDocSearch": {
          "type": "number",
          "default": 3,
          "description": "Maximum number of agentic search rounds for Advanced Doc Search. Each round evaluates doc summaries, marks irrelevant docs, and reads promising content."
        },
        "repoAsk.maxSearchResults": {
          "type": "number",
          "default": 5,
          "description": "Maximum number of documents to return from a ranked search. Acts as the hard cap after scoring, cutoff, and knowledge graph traversal."
        },
        "repoAsk.topScoreThresholdRatio": {
          "type": "number",
          "default": 0.3,
          "description": "Score threshold ratio for filtering ranked documents. Documents scoring below this fraction of the top score are removed. Range: 0.0–1.0. Lower values keep more documents; higher values are stricter."
        },
        "repoAsk.keywords": {
          "type": "object",
          "default": {
            "KEYWORD_LIMIT": 100,
            "KEYWORD_LIMIT_DOC_LOGARITHMIC_GROWTH_FACTOR": 10
          },
          "description": "Keyword extraction limits used during document indexing.",
          "additionalProperties": false,
          "properties": {
            "KEYWORD_LIMIT": {
              "type": "number",
              "description": "Maximum number of semantic and structural keywords stored per document."
            },
            "KEYWORD_LIMIT_DOC_LOGARITHMIC_GROWTH_FACTOR": {
              "type": "number",
              "description": "Growth factor for keyword limit based on document length. The actual keyword limit for a document is calculated as KEYWORD_LIMIT + log(document_length) * KEYWORD_LIMIT_DOC_LOGARITHMIC_GROWTH_FACTOR."
            }
          }
        },
        "repoAsk.bm25": {
          "type": "object",
          "default": {
            "k1": 1.2,
            "b": 0.75,
            "BM25_KEYWORD_LIMIT": 30,
            "BM25_KEYWORD_LIMIT_DOC_LOGARITHMIC_GROWTH_FACTOR": 10,
            "BM25_KEYWORD_LIMIT_DOC_NUM_LOGARITHMIC_GROWTH_FACTOR": 10
          },
          "description": "BM25 scoring parameters used during the second-pass keyword extraction. k1 controls term-frequency saturation (higher = less saturation); b controls document-length normalisation (0 = none, 1 = full). BM25_KEYWORD_LIMIT caps the number of BM25 keywords stored per document.",
          "additionalProperties": false,
          "properties": {
            "k1": {
              "type": "number",
              "description": "Term-frequency saturation parameter. Typical range: 1.2-2.0."
            },
            "b": {
              "type": "number",
              "description": "Document-length normalisation factor. Range: 0.0-1.0."
            },
            "BM25_KEYWORD_LIMIT": {
              "type": "number",
              "description": "Maximum number of BM25 keywords to store per document."
            },
            "BM25_KEYWORD_LIMIT_DOC_LOGARITHMIC_GROWTH_FACTOR": {
              "type": "number",
              "description": "Growth factor for BM25 keyword limit based on document length. The actual BM25 keyword limit for a document is calculated as BM25_KEYWORD_LIMIT + log(document_length) * BM25_KEYWORD_LIMIT_DOC_LOGARITHMIC_GROWTH_FACTOR."
            },
            "BM25_KEYWORD_LIMIT_DOC_NUM_LOGARITHMIC_GROWTH_FACTOR": {
              "type": "number",
              "description": "Growth factor for BM25 keyword limit based on total number of documents. The actual BM25 keyword limit is further increased by log(total_document_count) * BM25_KEYWORD_LIMIT_DOC_NUM_LOGARITHMIC_GROWTH_FACTOR to allow more keywords as the document store grows."
            }
          }
        },
        "repoAsk.skipWords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "and",
            "or",
            "but",
            "if",
            "then",
            "else",
            "when",
            "at",
            "by",
            "for",
            "with",
            "without",
            "on",
            "in",
            "to",
            "from",
            "of",
            "as",
            "is",
            "are",
            "was",
            "were",
            "be",
            "been",
            "being",
            "have",
            "has",
            "had",
            "do",
            "does",
            "did",
            "will",
            "would",
            "shall",
            "should",
            "can",
            "get",
            "set",
            "let",
            "make",
            "go",
            "come",
            "see",
            "look",
            "know",
            "think",
            "say",
            "tell",
            "ask",
            "answer",
            "help",
            "use",
            "used",
            "using",
            "need",
            "want",
            "require",
            "include",
            "check",
            "checking",
            "investigate",
            "investigating",
            "try",
            "trying",
            "run",
            "running",
            "investigation",
            "review",
            "reviewing",
            "discuss",
            "discussing",
            "discussion",
            "could",
            "may",
            "might",
            "must",
            "a",
            "an",
            "the",
            "it",
            "this",
            "that",
            "these",
            "those",
            "i",
            "you",
            "he",
            "she",
            "they",
            "we",
            "me",
            "him",
            "her",
            "them",
            "us",
            "my",
            "your",
            "his",
            "its",
            "our",
            "their",
            "mine",
            "yours",
            "hers",
            "ours",
            "theirs",
            "what",
            "which",
            "who",
            "whom",
            "whose",
            "all",
            "any",
            "both",
            "each",
            "few",
            "more",
            "most",
            "other",
            "some",
            "such",
            "no",
            "nor",
            "not",
            "only",
            "own",
            "same",
            "so",
            "than",
            "too",
            "very",
            "s",
            "t",
            "just",
            "don",
            "now"
          ],
          "description": "Additional words to exclude from keyword generation. These are merged with the built-in stop word list (conjunctions, pronouns, common verbs, etc.). Applies to 1-gram keyword entries across all keyword categories."
        },
        "repoAsk.logActionConfluenceUrl": {
          "type": "string",
          "default": "",
          "description": "Static URL of the target Confluence page where new feedback entries will be appended."
        },
        "repoAsk.usernameAlias": {
          "type": "string",
          "default": "Anonymous",
          "description": "Username alias to use for feedback submissions when user profile cannot be determined."
        },
        "repoAsk.searchWeights": {
          "type": "object",
          "default": {
            "WHOLE_QUERY_WEIGHTS": {
              "id": 50,
              "title": 35,
              "keywords": 8,
              "tags": 6,
              "type": 4,
              "referencedExact": 40,
              "referencedPartial": 20
            },
            "TERM_WEIGHTS": {
              "id": 5,
              "title": 3,
              "keywords": 1,
              "tags": 4,
              "type": 3,
              "referenced": 4
            },
            "keywords": {
              "title": {
                "1gram": 10,
                "2gram": 20,
                "3gram": 30,
                "4gram": 40
              },
              "structural": {
                "1gram": 5,
                "2gram": 8,
                "3gram": 12,
                "4gram": 16
              },
              "semantic": {
                "1gram": 4,
                "2gram": 7,
                "3gram": 10,
                "4gram": 14
              },
              "bm25": {
                "1gram": 6,
                "2gram": 10,
                "3gram": 14,
                "4gram": 18
              },
              "kg": {
                "1gram": 3,
                "2gram": 5,
                "3gram": 8,
                "4gram": 11
              },
              "synonyms": {
                "1gram": 2,
                "2gram": 4,
                "3gram": 6,
                "4gram": 8
              }
            },
            "KNOWLEDGE_GRAPH_WEIGHTS": {
              "entityTraversalBoost": 0.25,
              "sharedTopicBoost": 0.15,
              "maxHops": 1
            }
          },
          "description": "Ranking search weights for local documents."
        },
        "repoAsk.confluence": {
          "type": "object",
          "default": {
            "key": "ALM",
            "isDefault": true,
            "url": "http://localhost:8091",
            "spaceKey": "",
            "ancestorsPageId": "",
            "securityToken": ""
          },
          "description": "Confluence connection profile used by RepoAsk.",
          "additionalProperties": false,
          "properties": {
            "key": {
              "type": "string",
              "description": "Profile key for the Confluence connection."
            },
            "isDefault": {
              "type": "boolean",
              "description": "Whether this connection is the default profile."
            },
            "url": {
              "type": "string",
              "description": "Base URL for the Confluence API endpoint."
            },
            "spaceKey": {
              "type": "string",
              "description": "Optional default Confluence space key."
            },
            "ancestorsPageId": {
              "type": "string",
              "description": "Optional default ancestors page id."
            },
            "securityToken": {
              "type": "string",
              "description": "Optional Confluence access token."
            }
          }
        },
        "repoAsk.jira": {
          "type": "object",
          "default": {
            "key": "ALM",
            "isDefault": true,
            "url": "http://localhost:8092",
            "securityToken": "",
            "regex": [
              "PROJECT-\\d+",
              "PROJ-\\d+"
            ]
          },
          "description": "Jira connection profile used by RepoAsk.",
          "additionalProperties": false,
          "properties": {
            "key": {
              "type": "string",
              "description": "Profile key for the Jira connection."
            },
            "isDefault": {
              "type": "boolean",
              "description": "Whether this connection is the default profile."
            },
            "url": {
              "type": "string",
              "description": "Base URL for the Jira API endpoint."
            },
            "securityToken": {
              "type": "string",
              "description": "Optional Jira access token."
            },
            "regex": {
              "type": "array",
              "description": "List of regex patterns used to extract Jira issue keys from parse arg input.",
              "items": {
                "type": "string"
              },
              "default": [
                "PROJECT-\\d+",
                "PROJ-\\d+"
              ]
            }
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "node build.js",
    "watch": "node build.js --watch",
    "lint": "eslint src",
    "pretest": "npm run compile",
    "test": "node ./test/runTest.js",
    "vsce:package": "npm run compile && vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/axios": "^0.14.0",
    "@types/cheerio": "^0.22.31",
    "@types/glob": "^8.0.3",
    "@types/markdown-it": "^13.0.7",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/vscode": "^1.106.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "eslint": "^8.40.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@langchain/core": "^1.1.35",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "langchain": "^1.2.36",
    "markdown-it": "^14.1.1",
    "turndown": "^7.2.2"
  }
}
