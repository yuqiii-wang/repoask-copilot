{
  "name": "repo-ask",
  "displayName": "@RepoAsk",
  "description": "A VS Code plugin for searching and managing Confluence documentation",
  "version": "0.1.0",
  "publisher": "repo-ask",
  "engines": {
    "vscode": ">=1.106.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:repo-ask-documents",
    "onChatParticipant:repoaskDoc",
    "onChatParticipant:repoaskCode",
    "onLanguageModelTool:repoask_rank",
    "onLanguageModelTool:repoask_doc_check",
    "onLanguageModelTool:repoask_read_metadata",
    "onLanguageModelTool:repoask_read_content",
    "onLanguageModelTool:repoask_new_code_check",
    "onLanguageModelTool:repoask_read_repo_prompts"
  ],
  "main": "index.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "repoaskDoc",
        "name": "repoaskDoc",
        "description": "RepoAsk chat for general questions from the document store"
      },
      {
        "id": "repoaskCode",
        "name": "repoaskCode",
        "description": "RepoAsk chat for local code review and changes"
      }
    ],
    "languageModelTools": [
      {
        "name": "repoask_rank",
        "tags": [
          "repoask",
          "search",
          "rank"
        ],
        "toolReferenceName": "repoaskRank",
        "displayName": "RepoAsk Rank",
        "modelDescription": "Rank local documents using IDF scoring over local metadata and markdown content.",
        "userDescription": "Find top matching local documents.",
        "canBeReferencedInPrompt": true,
        "icon": "$(list-ordered)",
        "inputSchema": {
          "type": "object",
          "required": [
            "query"
          ],
          "properties": {
            "query": {
              "type": "string",
              "description": "Query terms used to rank local documents."
            },
            "limit": {
              "type": "number",
              "description": "Optional max number of results to return.",
              "default": 3
            }
          }
        }
      },
      {
        "name": "repoask_doc_check",
        "tags": [
          "repoask",
          "relevance",
          "qa"
        ],
        "toolReferenceName": "repoaskDocCheck",
        "displayName": "RepoAsk Doc Check",
        "modelDescription": "Find relevant local documents for a question using metadata relevance and include local content references.",
        "userDescription": "Check local docs for relevant references.",
        "canBeReferencedInPrompt": true,
        "icon": "$(search)",
        "inputSchema": {
          "type": "object",
          "required": [
            "query"
          ],
          "properties": {
            "query": {
              "type": "string",
              "description": "User question to evaluate against local metadata and content."
            },
            "limit": {
              "type": "number",
              "description": "Optional max number of references to return.",
              "default": 3
            }
          }
        }
      },
      {
        "name": "repoask_read_metadata",
        "tags": [
          "repoask",
          "metadata",
          "read"
        ],
        "toolReferenceName": "repoaskReadMetadata",
        "displayName": "RepoAsk Read Metadata",
        "modelDescription": "Read the metadata of local documents.",
        "userDescription": "Read the metadata of local documents.",
        "canBeReferencedInPrompt": true,
        "icon": "$(bracket)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "ids": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Optional list of document ids to read metadata for. Leave empty to read all metadata."
            }
          }
        }
      },
      {
        "name": "repoask_read_content",
        "tags": [
          "repoask",
          "content",
          "read"
        ],
        "toolReferenceName": "repoaskReadContent",
        "displayName": "RepoAsk Read Content",
        "modelDescription": "Read the full markdown content of local documents.",
        "userDescription": "Read the content of local documents.",
        "canBeReferencedInPrompt": true,
        "icon": "$(file)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "ids": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Optional list of document ids to read content for. Leave empty to read all."
            }
          }
        }
      },
      {
        "name": "repoask_new_code_check",
        "tags": [
          "repoask",
          "code",
          "diff",
          "review",
          "test"
        ],
        "toolReferenceName": "repoaskNewCodeCheck",
        "displayName": "RepoAsk New Code Check",
        "modelDescription": "Get git diff of the current branch compared to main/master to do code review, generate tests, and verify against guides.",
        "userDescription": "Compare current branch with main/master via git diff.",
        "canBeReferencedInPrompt": true,
        "icon": "$(git-compare)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "repoask_read_repo_prompts",
        "tags": [
          "repoask",
          "prompts",
          "code"
        ],
        "toolReferenceName": "repoaskReadRepoPrompts",
        "displayName": "RepoAsk Read Repo Prompts",
        "modelDescription": "Read the .github/prompts/*.prompt.md files and return their content to be used as instructions/guides.",
        "userDescription": "Read repository code guidelines prompts.",
        "canBeReferencedInPrompt": true,
        "icon": "$(file)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "repo-ask-explorer",
          "title": "RepoAsk",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "repo-ask-explorer": [
        {
          "id": "repo-ask-documents",
          "name": "Documents",
          "type": "webview",
          "icon": "media/icon.svg"
        }
      ]
    },
    "configuration": {
      "title": "RepoAsk",
      "properties": {
        "repoAsk.initKeywordNum": {
          "type": "number",
          "default": 50,
          "description": "Init Keyword Num"
        },
        "repoAsk.confluence": {
          "type": "object",
          "default": {
            "key": "ALM",
            "isDefault": true,
            "url": "http://localhost:8001",
            "spaceKey": "",
            "ancestorsPageId": "",
            "securityToken": ""
          },
          "description": "Confluence connection profile used by RepoAsk.",
          "additionalProperties": false,
          "properties": {
            "key": {
              "type": "string",
              "description": "Profile key for the Confluence connection."
            },
            "isDefault": {
              "type": "boolean",
              "description": "Whether this connection is the default profile."
            },
            "url": {
              "type": "string",
              "description": "Base URL for the Confluence API endpoint."
            },
            "spaceKey": {
              "type": "string",
              "description": "Optional default Confluence space key."
            },
            "ancestorsPageId": {
              "type": "string",
              "description": "Optional default ancestors page id."
            },
            "securityToken": {
              "type": "string",
              "description": "Optional Confluence access token."
            }
          }
        },
        "repoAsk.jira": {
          "type": "object",
          "default": {
            "key": "ALM",
            "isDefault": true,
            "url": "http://localhost:8002",
            "securityToken": "",
            "regex": [
              "PROJECT-\\d+",
              "PROJ-\\d+"
            ]
          },
          "description": "Jira connection profile used by RepoAsk.",
          "additionalProperties": false,
          "properties": {
            "key": {
              "type": "string",
              "description": "Profile key for the Jira connection."
            },
            "isDefault": {
              "type": "boolean",
              "description": "Whether this connection is the default profile."
            },
            "url": {
              "type": "string",
              "description": "Base URL for the Jira API endpoint."
            },
            "securityToken": {
              "type": "string",
              "description": "Optional Jira access token."
            },
            "regex": {
              "type": "array",
              "description": "List of regex patterns used to extract Jira issue keys from parse arg input.",
              "items": {
                "type": "string"
              },
              "default": [
                "PROJECT-\\d+",
                "PROJ-\\d+"
              ]
            }
          }
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js",
    "compile": "echo Compile completed"
  },
  "devDependencies": {
    "@types/glob": "^8.0.3",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.106.0",
    "@vscode/test-electron": "^2.3.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.40.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "markdown-it": "^14.1.1",
    "turndown": "^7.2.2"
  }
}